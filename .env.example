# ============================================================
# TeenPatti Lucky Bot 环境变量配置
# ============================================================
# 
# 使用说明：
# 1. 复制此文件为 .env (cp .env.example .env)
# 2. 填入实际值
# 3. 重启服务生效
#
# 或者直接在 Railway/Docker 中设置环境变量
# ============================================================

# -------------------- 核心配置 --------------------

# Telegram Bot Token (从 @BotFather 获取)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 管理员 Telegram ID (多个用逗号分隔)
ADMIN_IDS=123456789,987654321

# -------------------- 私域流量配置 --------------------

# 官方频道数字ID (格式: -100xxxxxxxxxx)
# 获取方法：转发频道消息给 @userinfobot
CHANNEL_ID=-1003881508220

# 官方频道用户名 (格式: @channelname)
# 用于显示和跳转链接
CHANNEL_USERNAME=@telltest222

# 玩家群组数字ID (格式: -100xxxxxxxxxx)
GROUP_ID=-1003858436956

# 玩家群组用户名 (格式: @groupname)
# 用于显示和跳转链接
GROUP_USERNAME=@tkgfg

# 是否强制要求关注频道 (true/false)
REQUIRE_CHANNEL_SUBSCRIPTION=false

# -------------------- AI 内容生成配置 --------------------

# ===== 方案 1: Kimi API (推荐，需要充值) =====
# 从 https://platform.moonshot.cn/ 获取
KIMI_API_KEY=YOUR_KIMI_API_KEY_HERE
KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions
KIMI_MODEL=moonshot-v1-8k

# ===== 方案 2: OpenRouter (免费替代方案) =====
# 从 https://openrouter.ai/ 获取免费 API Key
# 支持模型: google/gemma-2-9b-it:free, meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# ===== 方案 3: 禁用 AI (只用模板) =====
# 不设置任何 API Key，系统自动使用预设模板

# -------------------- 其他配置 --------------------

# 时区设置
TIMEZONE=Asia/Kolkata

# 货币符号
CURRENCY=₹

# ============================================================
# 示例：更换频道/群组时的操作步骤
# ============================================================
#
# 1. 创建新的 Telegram 频道/群组
# 2. 将机器人设为管理员
# 3. 获取新的 ID 和用户名
# 4. 在 Railway/Docker 中更新以下环境变量：
#    - CHANNEL_ID
#    - CHANNEL_USERNAME
#    - GROUP_ID
#    - GROUP_USERNAME
# 5. 点击 Redeploy 重新部署
# 6. 完成！所有欢迎消息自动使用新配置
#
# ============================================================

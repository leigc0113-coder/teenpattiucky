# TeenPatti Lucky Bot 环境变量配置
# 复制此文件为 .env 并填入实际值

# Telegram Bot Token (从 @BotFather 获取)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 管理员 Telegram ID (多个用逗号分隔)
ADMIN_IDS=123456789,987654321

# 官方频道 ID (数字格式，如 -1001234567890)
# 获取方法：转发频道消息给 @userinfobot
CHANNEL_ID=-1003881508220

# 玩家群组 ID (数字格式，如 -1000987654321)
GROUP_ID=-1003858436956

# 是否强制要求关注频道 (true/false)
REQUIRE_CHANNEL_SUBSCRIPTION=false

# 时区设置
TIMEZONE=Asia/Kolkata

# 货币符号
CURRENCY=₹
